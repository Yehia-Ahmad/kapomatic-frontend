{
  "name": "kapomatic-inventory-system",
  "version": "0.0.0",
  "description": "Kapomatic Inventory System",
  "author": "Kapomatic",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:desktop": "ng build --base-href ./",
    "electron:start": "npm run build:desktop && electron .",
    "electron:build:dir": "npm run build:desktop && electron-builder --dir",
    "electron:build:win": "npm run build:desktop && electron-builder --win nsis",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:okland-warranty-system": "node dist/okland-warranty-system/server/server.mjs",
    "clean": "rm -rf node_modules .angular/cache node_modules/.vite",
    "reinstall": "npm run clean && npm install"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "build": {
    "appId": "com.kapomatic.inventory",
    "productName": "Kapomatic Inventory System",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "icon": "src/assets/img/Kapo.jpeg",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/img/Kapo.jpeg",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.8",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-server": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/ssr": "^20.3.5",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@primeuix/themes": "^1.2.5",
    "angular-svg-icon": "^19.1.1",
    "angularx-qrcode": "^20.0.0",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "primeng": "^20.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.5",
    "@angular/cli": "^20.3.5",
    "@angular/compiler-cli": "^20.3.0",
    "@types/express": "^5.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.17.19",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.2"
  }
}
